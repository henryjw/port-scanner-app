{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "angular-electron": {
      "root": "projects/angular-electron",
      "sourceRoot": "projects/angular-electron/src",
      "projectType": "application",
      "schematics": {
        "@schematics/angular:application": {
          "strict": true
        },
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "outputPath": "dist",
            "index": "projects/angular-electron/src/index.html",
            "main": "projects/angular-electron/src/main.ts",
            "tsConfig": "projects/angular-electron/src/tsconfig.app.json",
            "polyfills": "projects/angular-electron/src/polyfills.ts",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/angular-electron/src/favicon.ico",
              "projects/angular-electron/src/assets"
            ],
            "styles": [
              "projects/angular-electron/src/styles.scss"
            ],
            "scripts": [],
            "customWebpackConfig": {
              "path": "./angular.webpack.js",
              "replaceDuplicatePlugins": true
            }
          },
          "configurations": {
            "dev": {
              "optimization": false,
              "outputHashing": "none",
              "sourceMap": true,
              "namedChunks": false,
              "aot": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": false,
              "fileReplacements": [
                {
                  "replace": "projects/angular-electron/src/environments/environment.ts",
                  "with": "projects/angular-electron/src/environments/environment.dev.ts"
                }
              ]
            },
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "fileReplacements": [
                {
                  "replace": "projects/angular-electron/src/environments/environment.ts",
                  "with": "projects/angular-electron/src/environments/environment.prod.ts"
                }
              ]
            },
            "web": {
              "optimization": false,
              "outputHashing": "none",
              "sourceMap": true,
              "namedChunks": false,
              "aot": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": false,
              "fileReplacements": [
                {
                  "replace": "projects/angular-electron/src/environments/environment.ts",
                  "with": "projects/angular-electron/src/environments/environment.web.ts"
                }
              ]
            },
            "web-production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "fileReplacements": [
                {
                  "replace": "projects/angular-electron/src/environments/environment.ts",
                  "with": "projects/angular-electron/src/environments/environment.web.prod.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular-builders/custom-webpack:dev-server",
          "options": {
            "browserTarget": "angular-electron:build"
          },
          "configurations": {
            "dev": {
              "browserTarget": "angular-electron:build:dev"
            },
            "production": {
              "browserTarget": "angular-electron:build:production"
            },
            "web": {
              "browserTarget": "angular-electron:build:web"
            },
            "web-production": {
              "browserTarget": "angular-electron:build:web-production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "angular-electron:build"
          }
        },
        "test": {
          "builder": "@angular-builders/custom-webpack:karma",
          "options": {
            "main": "projects/angular-electron/src/test.ts",
            "polyfills": "projects/angular-electron/src/polyfills-test.ts",
            "tsConfig": "projects/angular-electron/src/tsconfig.spec.json",
            "karmaConfig": "projects/angular-electron/src/karma.conf.js",
            "inlineStyleLanguage": "scss",
            "scripts": [],
            "styles": [
              "projects/angular-electron/src/styles.scss"
            ],
            "assets": [
              "projects/angular-electron/src/favicon.ico",
              "projects/angular-electron/src/assets"
            ],
            "customWebpackConfig": {
              "path": "./angular.webpack.js",
              "replaceDuplicatePlugins": true
            }
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/angular-electron/src/**/*.ts",
              "projects/angular-electron/src/**/*.html"
            ]
          }
        }
      }
    },
    "angular-electron-e2e": {
      "root": "projects/angular-electron-e2e",
      "sourceRoot": "projects/angular-electron-e2e/src",
      "projectType": "application",
      "architect": {
        "e2e": {
          "builder": "@nrwl/cypress:cypress",
          "options": {
            "cypressConfig": "projects/angular-electron-e2e/cypress.json",
            "devServerTarget": "angular-electron:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "angular-electron:serve:production"
            }
          }
        },
        "lint": {
          "builder": "@nrwl/linter:eslint",
          "outputs": [
            "{options.outputFile}"
          ],
          "options": {
            "lintFilePatterns": [
              "projects/angular-electron-e2e/**/*.{js,ts}"
            ]
          }
        }
      },
      "tags": [],
      "implicitDependencies": [
        "angular-electron"
      ]
    },
    "electron-e2e": {
      "root": "e2e",
      "projectType": "application",
      "architect": {
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "e2e/**/*.ts"
            ]
          }
        }
      }
    }
  }
}
